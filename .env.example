# Copy this file to .env and fill in the values.

# Telegram Bot Token — obtain from @BotFather on Telegram
BOT_TOKEN=

# Developer Telegram chat ID — unhandled exceptions are sent here as private messages.
# Get yours by messaging @userinfobot on Telegram.
DEV_CHAT_ID=

# SQLite database path (default: data/dnd_bot.db)
# DB_PATH=data/dnd_bot.db

# Telegram Mini App URL — the GitHub Pages URL where the React app is hosted.
# Register with BotFather via /newapp before setting this.
WEBAPP_URL=https://cioscos.github.io/dnd_bot_revamped/app/

# Cloudflare Tunnel public URL for the FastAPI backend.
# Used by the Mini App frontend as VITE_API_BASE_URL.
# CLOUDFLARE_TUNNEL_URL=https://api.yourdomain.com
